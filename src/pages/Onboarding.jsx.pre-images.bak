import React, { useState } from 'react';
import { C } from '../theme/colors';
import { useT } from '../i18n/translations';

export function Onboarding() {
  const t = useT('onboarding') || {};
  const [accountType, setAccountType] = useState('professional');
  const [profileTab, setProfileTab] = useState('basic');
  const [name, setName] = useState('');
  const [loc, setLoc] = useState('');
  const [personalPrimaryPhone, setPersonalPrimaryPhone] = useState('');
  const [portfolioRecordsTab, setPortfolioRecordsTab] = useState('properties');
  const [myPortfolio, setMyPortfolio] = useState([
    { id: 'p1', address: '123 Main St', city: 'Phoenix', price: 250000, images: [1], publishToShowcase: true, includeInPreview: false },
    { id: 'p2', address: '456 Oak Ave', city: 'Tucson', price: 175000, images: [], publishToShowcase: false, includeInPreview: false },
  ]);

  return (
    <div style={{ padding: 24 }}>
      <h2 style={{ marginBottom: 12 }}>Onboarding</h2>

      <div style={{ display: 'flex', gap: 16 }}>
        <div style={{ flex: 1, background: C.card, padding: 12, borderRadius: 10, border: `1px solid ${C.border}` }}>
          <div style={{ display: 'flex', justifyContent: 'space-between', alignItems: 'center', marginBottom: 8 }}>
            <div style={{ fontSize: 14, fontWeight: 700, color: C.t1 }}>Perfil</div>
            <div>
              <button onClick={() => setAccountType('basic')} style={{ marginRight: 6, padding: '6px 10px' }}>Basic</button>
              <button onClick={() => setAccountType('professional')} style={{ padding: '6px 10px' }}>Pro</button>
            </div>
          </div>

          <div style={{ display: 'grid', gap: 8 }}>
            <label style={{ display: 'grid', gap: 4 }}>
              <span style={{ fontSize: 11, color: C.t3 }}>Nome completo</span>
              <input value={name} onChange={(e) => setName(e.target.value)} placeholder="Seu nome" style={{ padding: '8px', borderRadius: 8, border: `1px solid ${C.border}`, background: C.card, color: C.t1 }} />
            </label>

            <label style={{ display: 'grid', gap: 4 }}>
              <span style={{ fontSize: 11, color: C.t3 }}>Estado / Cidade</span>
              <input value={loc} onChange={(e) => setLoc(e.target.value)} placeholder="Cidade, UF" style={{ padding: '8px', borderRadius: 8, border: `1px solid ${C.border}`, background: C.card, color: C.t1 }} />
            </label>

            <label style={{ display: 'grid', gap: 4 }}>
              <span style={{ fontSize: 11, color: C.t3 }}>Telefone</span>
              <input value={personalPrimaryPhone} onChange={(e) => setPersonalPrimaryPhone(e.target.value)} placeholder="(555) 555-5555" style={{ padding: '8px', borderRadius: 8, border: `1px solid ${C.border}`, background: C.card, color: C.t1 }} />
            </label>

            <div style={{ display: 'flex', gap: 8, marginTop: 8 }}>
              <button style={{ flex: 1, padding: '8px', borderRadius: 8, border: `1px solid ${C.accent}`, background: 'transparent', color: C.accent, fontWeight: 700 }}>Salvar</button>
              <button style={{ flex: 1, padding: '8px', borderRadius: 8, border: 'none', background: C.accent, color: '#111', fontWeight: 700 }}>Visualizar</button>
            </div>
          </div>
        </div>

        <div style={{ width: 360, background: C.card, padding: 12, borderRadius: 10, border: `1px solid ${C.border}` }}>
          <div style={{ fontSize: 14, fontWeight: 700, color: C.t1, marginBottom: 8 }}>Portfólio</div>
          <div style={{ fontSize: 12, color: C.t3, marginBottom: 8 }}>Adicione propriedades ou serviços ao seu portfólio.</div>
          <div style={{ display: 'grid', gap: 8 }}>
            <input placeholder="Endereço / título" style={{ padding: '8px', borderRadius: 8, border: `1px solid ${C.border}`, background: C.card, color: C.t1 }} />
            <input placeholder="Preço (USD)" style={{ padding: '8px', borderRadius: 8, border: `1px solid ${C.border}`, background: C.card, color: C.t1 }} />
            <button style={{ padding: '8px', borderRadius: 8, border: `1px solid ${C.accent}`, background: 'transparent', color: C.accent, fontWeight: 700 }}>+ Add</button>
          </div>

          <div style={{ marginTop: 12 }}>
            <div style={{ display: 'flex', gap: 8, marginBottom: 8 }}>
              <button onClick={() => setPortfolioRecordsTab('properties')} style={{ padding: '6px 10px', fontWeight: portfolioRecordsTab === 'properties' ? 700 : 400 }}>{portfolioRecordsTab === 'properties' ? 'Properties' : 'Properties'}</button>
              <button onClick={() => setPortfolioRecordsTab('services')} style={{ padding: '6px 10px', fontWeight: portfolioRecordsTab === 'services' ? 700 : 400 }}>{portfolioRecordsTab === 'services' ? 'Services' : 'Services'}</button>
            </div>

            <div style={{ border: `1px solid ${C.border}`, borderRadius: 8, padding: 8, maxHeight: 220, overflowY: 'auto', background: C.card }}>
              {portfolioRecordsTab === 'properties' ? (
                myPortfolio.length === 0 ? (
                  <div style={{ color: C.t3, fontSize: 12 }}>Nenhuma propriedade.</div>
                ) : (
                  <>
                    {myPortfolio.map((p, i) => (
                      <div key={p.id} style={{ display: 'flex', justifyContent: 'space-between', alignItems: 'center', padding: '6px 0', borderBottom: i < myPortfolio.length - 1 ? `1px solid ${C.border}` : 'none' }}>
                        <div style={{ minWidth: 0, overflow: 'hidden', textOverflow: 'ellipsis' }}>
                          <div style={{ fontSize: 12, fontWeight: 700, color: C.t1 }}>{p.address} · {p.city}</div>
                          <div style={{ fontSize: 11, color: C.t3 }}>${Math.round((p.price || 0) / 1000)}K · {p.images?.length || 0} img</div>
                        </div>
                        <div style={{ display: 'flex', gap: 6, marginLeft: 8 }}>
                          <button onClick={() => setMyPortfolio(prev => {
                            const idx = prev.findIndex(x => x.id === p.id);
                            if (idx <= 0) return prev;
                            const next = [...prev]; const tmp = next[idx-1]; next[idx-1] = next[idx]; next[idx] = tmp; return next;
                          })} style={{ padding: '6px', borderRadius: 6 }}>↑</button>
                          <button onClick={() => setMyPortfolio(prev => {
                            const idx = prev.findIndex(x => x.id === p.id);
                            if (idx === -1 || idx >= prev.length - 1) return prev;
                            const next = [...prev]; const tmp = next[idx+1]; next[idx+1] = next[idx]; next[idx] = tmp; return next;
                          })} style={{ padding: '6px', borderRadius: 6 }}>↓</button>
                          <button onClick={() => setMyPortfolio(prev => prev.filter(x => x.id !== p.id))} style={{ padding: '6px', borderRadius: 6, color: C.danger }}>✕</button>
                        </div>
                      </div>
                    ))}
                  </>
                )
              ) : (
                <div style={{ color: C.t3, fontSize: 12 }}>Serviços (em breve)</div>
              )}
            </div>
          </div>
        </div>
      </div>
    </div>
  );
}

export default Onboarding;
