VITE_SUPABASE_ANON_KEY=sua_chave_anon_publica_supabase

VITE_APP_URL=https://seu-app.vercel.app
VITE_USE_POLLING=true

VITE_STRIPE_PUBLISHABLE_KEY=pk_live_ou_pk_test_sua_chave_publica_stripe

# IDs de preço Stripe (formato: price_xxxxxxxx — copie do Dashboard Stripe)
VITE_STRIPE_PRICE_P5=price_xxxxxxxx
VITE_STRIPE_PRICE_P15=price_xxxxxxxx
VITE_STRIPE_PRICE_P40=price_xxxxxxxx
VITE_STRIPE_PRICE_P100=price_xxxxxxxx
VITE_STRIPE_PRICE_PLAN_PRO=price_xxxxxxxx
VITE_STRIPE_PRICE_PLAN_ENTERPRISE=price_xxxxxxxx

