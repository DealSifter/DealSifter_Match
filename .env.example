# Supabase (Vercel/frontend)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Stripe (Vercel/frontend)
VITE_STRIPE_PUBLISHABLE_KEY=pk_live_...

# Stripe Nugget Pack Price IDs (Vercel/frontend)
VITE_STRIPE_PRICE_P5=price_...
VITE_STRIPE_PRICE_P15=price_...
VITE_STRIPE_PRICE_P40=price_...
VITE_STRIPE_PRICE_P100=price_...

# Stripe Subscription Price IDs (Vercel/frontend)
VITE_STRIPE_PRICE_PLAN_PRO=price_...
VITE_STRIPE_PRICE_PLAN_ENTERPRISE=price_...

# Supabase Edge Function secrets (Supabase dashboard, not Vercel)
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Optional alias if your deployment scripts use this name instead.
STRIPE_WEBHOOK_SIGNING_SECRET=whsec_...
STRIPE_PRICE_P5=price_...
STRIPE_PRICE_P15=price_...
STRIPE_PRICE_P40=price_...
STRIPE_PRICE_P100=price_...
STRIPE_PRICE_PLAN_PRO=price_...
STRIPE_PRICE_PLAN_ENTERPRISE=price_...
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
APP_URL=https://your-app-domain.com

# App
VITE_APP_URL=https://your-app-domain.com

# Vite Dev Server - set "false" to disable polling in Linux/Mac CI
VITE_USE_POLLING=true
