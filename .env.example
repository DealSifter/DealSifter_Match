# Supabase
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Stripe (frontend)
VITE_STRIPE_PUBLISHABLE_KEY=pk_live_...

# Stripe Nugget Pack Price IDs (create in Stripe Dashboard → Products)
VITE_STRIPE_PRICE_P5=price_...
VITE_STRIPE_PRICE_P15=price_...
VITE_STRIPE_PRICE_P40=price_...
VITE_STRIPE_PRICE_P100=price_...

# App
VITE_APP_URL=https://your-app-domain.com

# Vite Dev Server - defina como "false" para desabilitar polling em Linux/Mac CI
VITE_USE_POLLING=true
